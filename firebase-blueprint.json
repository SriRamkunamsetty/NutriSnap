{
  "entities": {
    "User": {
      "title": "User Profile",
      "description": "User's personal data, goals, and metrics.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "height": { "type": "number", "description": "Height in cm" },
        "weight": { "type": "number", "description": "Weight in kg" },
        "bmi": { "type": "number" },
        "bodyType": { "type": "string", "enum": ["lean", "normal", "obese", "unknown"] },
        "fatEstimate": { "type": "number" },
        "goal": { "type": "string", "enum": ["lose", "maintain", "gain"] },
        "calorieLimit": { "type": "number" },
        "aiAvatarURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lastLoginAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email"]
    },
    "Scan": {
      "title": "Food Scan",
      "description": "Result of a food image analysis.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "foodName": { "type": "string" },
        "calories": { "type": "number" },
        "protein": { "type": "number" },
        "carbs": { "type": "number" },
        "fats": { "type": "number" },
        "confidence": { "type": "number" },
        "imageUrl": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "foodName", "calories", "timestamp"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in the AI nutrition coach chat.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "model"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "role", "text", "timestamp"]
    },
    "DailySummary": {
      "title": "Daily Summary",
      "description": "Aggregated nutritional data for a specific day.",
      "type": "object",
      "properties": {
        "date": { "type": "string", "format": "date" },
        "totalCalories": { "type": "number" },
        "totalProtein": { "type": "number" },
        "totalCarbs": { "type": "number" },
        "totalFats": { "type": "number" },
        "totalWater": { "type": "number" }
      },
      "required": ["date"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile documents."
    },
    "/users/{userId}/scans/{scanId}": {
      "schema": "Scan",
      "description": "User's food scan results."
    },
    "/users/{userId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "User's chat history with AI coach."
    },
    "/users/{userId}/daily_summary/{date}": {
      "schema": "DailySummary",
      "description": "User's daily nutritional summaries."
    }
  }
}
